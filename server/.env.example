PORT=3001

# Web app URL from Apps Script: Deploy → Web app (copy URL ending in /exec)
GOOGLE_APPS_SCRIPT_WEBAPP_URL=https://script.google.com/macros/s/XXXX/exec

# Same value as Script property WEBHOOK_SECRET in Apps Script (Project Settings → Script properties)
APPS_SCRIPT_SECRET=choose-a-long-random-string

# Comma-separated origins for CORS (production: your frontend URL)
# Default if unset: http://localhost:5173,http://127.0.0.1:5173
# CORS_ORIGIN=https://your-app.vercel.app
